generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pengguna {
  id_pengguna      String           @id @default(dbgenerated("('AC'::text || nextval('pengguna_code_seq'::regclass))")) @db.VarChar(20)
  nama_lengkap     String           @db.VarChar(100)
  email            String?          @unique @db.VarChar(150)
  nomor_telepon    String?          @unique @db.VarChar(20)
  kata_sandi       String?          @db.VarChar(255)
  google_id        String?          @unique @db.VarChar(100)
  kota_asal        String?          @db.VarChar(50)
  tanggal_lahir    DateTime?        @db.Date
  peran            peran_enum       @default(USER)
  status_akun      status_akun_enum @default(AKTIF)
  wa_terverifikasi Boolean          @default(false)
  kode_referral    String?          @db.VarChar(20)
  login_terakhir   DateTime?        @db.Timestamptz(6)
  dibuat_pada      DateTime?        @default(now()) @db.Timestamptz(6)
  diperbarui_pada  DateTime?        @default(now()) @db.Timestamptz(6)
  agent            Agent?
  mouKlien         Mou[]            @relation("MouKlien")
  klien            Klien[]

  @@index([kode_referral], map: "idx_kode_referral")
  @@index([email], map: "idx_pengguna_email")
  @@map("pengguna")
}

model Agent {
  id_agent               String                   @id @default(dbgenerated("('AG'::text || nextval('agent_code_seq'::regclass))")) @db.VarChar(20)
  id_pengguna            String                   @unique(map: "agent_id_pengguna_unique") @db.VarChar(20)
  nama_kantor            String                   @db.VarChar(100)
  kota_area              String                   @db.VarChar(50)
  jabatan                jabatan_agent_enum       @default(AGENT)
  id_upline              String?                  @db.VarChar(20)
  rating                 Decimal?                 @default(0.00) @db.Decimal(3, 2)
  jumlah_closing         Int                      @default(0)
  total_omset            Decimal?                 @default(0) @db.Decimal(18, 2)
  nomor_whatsapp         String                   @db.VarChar(20)
  poin                   Int                      @default(0)
  foto_ktp_url           String?
  foto_npwp_url          String?
  foto_profil_url        String?
  nama_bank              String?                  @db.VarChar(50)
  nomor_rekening         String?                  @db.VarChar(50)
  atas_nama_rekening     String?                  @db.VarChar(100)
  link_instagram         String?                  @db.VarChar(100)
  link_tiktok            String?                  @db.VarChar(100)
  link_facebook          String?                  @db.VarChar(100)
  status_keanggotaan     status_agent_enum        @default(PENDING)
  tanggal_gabung         DateTime?                @default(dbgenerated("CURRENT_DATE")) @db.Date
  dibuat_pada            DateTime?                @default(now()) @db.Timestamptz(6)
  diperbarui_pada        DateTime?                @default(now()) @db.Timestamptz(6)
  id_team_leader         String?                  @db.VarChar(20)
  acara                  Acara[]
  pengguna               Pengguna                 @relation(fields: [id_pengguna], references: [id_pengguna], onDelete: Cascade)
  teamLeader             Agent?                   @relation("AgentTeamLeader", fields: [id_team_leader], references: [id_agent])
  teamLeaderMembers      Agent[]                  @relation("AgentTeamLeader")
  upline                 Agent?                   @relation("AgentUpline", fields: [id_upline], references: [id_agent])
  downlines              Agent[]                  @relation("AgentUpline")
  berita                 Berita[]
  detailTransaksi        DetailTransaksi[]
  listings               Listing[]
  penukaranPoin          PenukaranPoin[]
  pesertaAcara           PesertaAcara[]
  pilihanPemilu          PilihanPemilu[]
  undanganAcara          UndanganAcara[]
  projectDibuat          Project[]
  projectInvestor        ProjectInvestor[]
  projectSelesaiInvestor ProjectSelesaiInvestor[]
  riwayatPoin            RiwayatPoin[]
  mouAgent               Mou[]                    @relation("MouAgent")
  leads                  Lead[]
  klien                  Klien[]
  propertyTitipKlaim     PropertyTitip[]          @relation("PropertyTitipKlaim")
  propertyTitipDistribusi PropertyTitipDistribution[]
  targetBulanan          TargetAgent[]            @relation("AgentTarget")

  @@index([jabatan], map: "idx_agent_jabatan")
  @@index([nama_kantor], map: "idx_agent_kantor")
  @@index([id_upline], map: "idx_agent_upline")
  @@index([id_team_leader], map: "idx_agent_team_leader")
  @@map("agent")
}

model Listing {
  id_property        BigInt                 @id @default(autoincrement())
  id_agent           String                 @db.VarChar(20)
  judul              String                 @db.VarChar(255)
  slug               String                 @unique(map: "listing_slug_unique") @db.VarChar(300)
  deskripsi          String?
  jenis_transaksi    jenis_transaksi_enum
  kategori           kategori_properti_enum
  vendor             String?                @db.VarChar(200)
  status_tayang      status_properti_enum   @default(TERSEDIA)
  harga              Decimal                @db.Decimal(20, 2)
  harga_per_meter    Decimal?               @db.Decimal(20, 2)
  harga_promo        Decimal?               @db.Decimal(20, 2)
  tanggal_lelang     DateTime?              @db.Timestamptz(6)
  uang_jaminan       Decimal?               @db.Decimal(20, 2)
  nilai_limit_lelang Decimal?               @db.Decimal(20, 2)
  link               String?                @db.VarChar(500)
  alamat_lengkap     String?                @db.VarChar(500)
  provinsi           String?                @db.VarChar(355)
  kota               String                 @db.VarChar(355)
  kecamatan          String?                @db.VarChar(355)
  kelurahan          String?                @db.VarChar(355)
  latitude           Decimal?               @db.Decimal(10, 8)
  longitude          Decimal?               @db.Decimal(11, 8)
  luas_tanah         Decimal?               @db.Decimal(12, 2)
  luas_bangunan      Decimal?               @db.Decimal(12, 2)
  jumlah_lantai      Int                    @default(1)
  kamar_tidur        Int?
  kamar_mandi        Int?
  daya_listrik       Int?
  sumber_air         String?                @db.VarChar(50)
  hadap_bangunan     String?                @db.VarChar(20)
  kondisi_interior   String?                @db.VarChar(50)
  legalitas          sertifikat_enum?
  nomor_legalitas    String?                @db.VarChar(250)
  gambar             String?
  lampiran           String?
  dilihat            Int                    @default(0)
  wa_click_count     Int                    @default(0)
  is_hot_deal        Boolean                @default(false)
  tanggal_dibuat     DateTime?              @default(now()) @db.Timestamptz(6)
  tanggal_diupdate   DateTime?              @default(now()) @db.Timestamptz(6)
  acara              Acara[]
  agent              Agent                  @relation(fields: [id_agent], references: [id_agent], onDelete: Cascade)
  listingBoosts      ListingBoost[]
  pilihanPemilu      PilihanPemilu[]
  project            Project[]
  projectSelesai     ProjectSelesai[]
  mou                Mou[]
  leads              Lead[]
  klien              Klien[]

  @@index([kota], map: "idx_property_lokasi")
  @@index([jenis_transaksi], map: "idx_property_jenis")
  @@index([id_agent], map: "idx_property_agent")
  @@index([slug], map: "idx_property_slug")
  @@map("listing")
}

model Project {
  id_project             String               @id @default(dbgenerated("('FLP'::text || lpad((nextval('project_code_seq'::regclass))::text, 4, '0'::text))")) @db.VarChar(20)
  id_listing             BigInt
  nama_project           String               @db.VarChar(255)
  alamat_property        String?              @db.VarChar(500)
  provinsi               String?              @db.VarChar(355)
  kota                   String?              @db.VarChar(355)
  kecamatan              String?              @db.VarChar(355)
  kelurahan              String?              @db.VarChar(355)
  gambar_thumbnail       String?              @db.VarChar(500)
  tanggal_pembelian      DateTime?            @db.Date
  harga_pembelian        Decimal              @default(0) @db.Decimal(20, 2)
  estimasi_harga_jual    Decimal              @default(0) @db.Decimal(20, 2)
  estimasi_profit_bersih Decimal              @default(0) @db.Decimal(20, 2)
  target_pendanaan       Decimal              @default(0) @db.Decimal(20, 2)
  total_pendanaan        Decimal              @default(0) @db.Decimal(20, 2)
  jenis_pendanaan        jenis_pendanaan_enum
  status                 status_project_enum  @default(pendanaan_terbuka)
  mulai_tanggal          DateTime?            @db.Date
  estimasi_selesai       DateTime?            @db.Date
  estimasi_bulan         Int                  @default(0)
  pendanaan_ditutup_pada DateTime?            @db.Date
  deskripsi_project      String?
  dibuat_oleh            String               @db.VarChar(20)
  nilai_limit_lelang     Decimal              @default(0) @db.Decimal(20, 2)
  spare_bidding          Decimal              @default(0) @db.Decimal(20, 2)
  biaya_eksekusi         Decimal              @default(0) @db.Decimal(20, 2)
  biaya_renov            Decimal              @default(0) @db.Decimal(20, 2)
  biaya_balik_nama       Decimal              @default(0) @db.Decimal(20, 2)
  total_biaya_akuisisi   Decimal              @default(0) @db.Decimal(20, 2)
  dana_cadangan          Decimal              @default(0) @db.Decimal(20, 2)
  dibuat_tanggal         DateTime             @default(now()) @db.Timestamptz(6)
  diupdate_tanggal       DateTime             @default(now()) @db.Timestamptz(6)
  pembuat                Agent                @relation(fields: [dibuat_oleh], references: [id_agent], map: "project_dibuat_oleh_fk")
  listing                Listing              @relation(fields: [id_listing], references: [id_property], map: "project_listing_fk")
  arusKas                ProjectArusKas[]
  cmaEntries             ProjectCma[]
  investorProject        ProjectInvestor[]
  projectSelesai         ProjectSelesai?

  @@index([id_listing], map: "idx_project_listing")
  @@index([dibuat_oleh], map: "idx_project_dibuat_oleh")
  @@index([status], map: "idx_project_status")
  @@index([jenis_pendanaan], map: "idx_project_jenis_pendanaan")
  @@index([kota], map: "idx_project_kota")
  @@map("project")
}

model ProjectInvestor {
  id_project_investor    BigInt                         @id @default(autoincrement())
  id_project             String                         @db.VarChar(20)
  id_agent               String                         @db.VarChar(20)
  nominal_komitmen       Decimal                        @default(0) @db.Decimal(20, 2)
  persentase_kepemilikan Decimal?                       @db.Decimal(10, 6)
  status                 status_pembayaran_project_enum @default(menunggu_pembayaran)
  dibuat_tanggal         DateTime                       @default(now()) @db.Timestamptz(6)
  diupdate_tanggal       DateTime                       @updatedAt @db.Timestamptz(6)
  agent                  Agent                          @relation(fields: [id_agent], references: [id_agent], onDelete: Cascade, map: "project_investor_agent_fk")
  project                Project                        @relation(fields: [id_project], references: [id_project], onDelete: Cascade, map: "project_investor_project_fk")

  @@unique([id_project, id_agent], map: "project_investor_unique")
  @@index([id_project], map: "idx_project_investor_project")
  @@index([id_agent], map: "idx_project_investor_agent")
  @@index([status], map: "idx_project_investor_status")
  @@map("project_investor")
}

model ProjectSelesai {
  id_project            String                   @id @db.VarChar(20)
  id_listing            BigInt
  tanggal_pembelian     DateTime?                @db.Date
  tanggal_terjual       DateTime                 @db.Date
  durasi_hari           Int
  harga_jual            Decimal                  @default(0) @db.Decimal(20, 2)
  total_biaya_akuisisi  Decimal                  @default(0) @db.Decimal(20, 2)
  profit_kotor          Decimal                  @default(0) @db.Decimal(20, 2)
  pph_percent           Decimal                  @default(0) @db.Decimal(5, 2)
  ajb_percent           Decimal                  @default(0) @db.Decimal(5, 2)
  agent_fee_percent     Decimal                  @default(0) @db.Decimal(5, 2)
  total_biaya_transaksi Decimal                  @default(0) @db.Decimal(20, 2)
  profit_bersih         Decimal                  @default(0) @db.Decimal(20, 2)
  roi_bersih            Decimal                  @default(0) @db.Decimal(10, 2)
  dibuat_tanggal        DateTime                 @default(now()) @db.Timestamptz(6)
  diupdate_tanggal      DateTime                 @updatedAt @db.Timestamptz(6)
  listing               Listing                  @relation(fields: [id_listing], references: [id_property], map: "project_selesai_listing_fk")
  project               Project                  @relation(fields: [id_project], references: [id_project], onDelete: Cascade, map: "project_selesai_project_fk")
  investorSelesai       ProjectSelesaiInvestor[]

  @@index([id_listing], map: "idx_project_selesai_listing")
  @@index([tanggal_terjual], map: "idx_project_selesai_tanggal_terjual")
  @@map("project_selesai")
}

model ProjectSelesaiInvestor {
  id_project     String         @db.VarChar(20)
  id_agent       String         @db.VarChar(20)
  modal          Decimal        @default(0) @db.Decimal(20, 2)
  porsi_percent  Decimal        @default(0) @db.Decimal(10, 6)
  profit         Decimal        @default(0) @db.Decimal(20, 2)
  total_diterima Decimal        @default(0) @db.Decimal(20, 2)
  agent          Agent          @relation(fields: [id_agent], references: [id_agent], onDelete: Cascade, map: "project_selesai_investor_agent_fk")
  projectSelesai ProjectSelesai @relation(fields: [id_project], references: [id_project], onDelete: Cascade, map: "project_selesai_investor_project_fk")

  @@id([id_project, id_agent])
  @@index([id_agent], map: "idx_project_selesai_investor_agent")
  @@map("project_selesai_investor")
}

model ProjectCma {
  id_project_cma   BigInt   @id @default(autoincrement())
  id_project       String   @db.VarChar(20)
  nama             String   @db.VarChar(255)
  luas_tanah       Decimal  @default(0) @db.Decimal(12, 2)
  harga            Decimal  @default(0) @db.Decimal(20, 2)
  catatan          String?
  dibuat_tanggal   DateTime @default(now()) @db.Timestamptz(6)
  diupdate_tanggal DateTime @default(now()) @db.Timestamptz(6)
  project          Project  @relation(fields: [id_project], references: [id_project], onDelete: Cascade, map: "project_cma_project_fk")

  @@index([id_project], map: "idx_project_cma_project")
  @@map("project_cma")
}

model ProjectArusKas {
  id_project_arus_kas BigInt                 @id @default(autoincrement())
  id_project          String                 @db.VarChar(20)
  tanggal_transaksi   DateTime               @db.Date
  jenis_transaksi     jenis_arus_kas_enum
  kategori_transaksi  kategori_arus_kas_enum
  judul_transaksi     String                 @db.VarChar(255)
  nominal             Decimal                @default(0) @db.Decimal(20, 2)
  status_transaksi    status_arus_kas_enum   @default(tercatat)
  catatan             String?
  dibuat_tanggal      DateTime               @default(now()) @db.Timestamptz(6)
  diupdate_tanggal    DateTime               @updatedAt @db.Timestamptz(6)
  wallet_key          wallet_key_enum
  project             Project                @relation(fields: [id_project], references: [id_project], onDelete: Cascade, map: "project_arus_kas_project_fk")

  @@index([id_project], map: "idx_project_arus_kas_project")
  @@index([wallet_key], map: "idx_project_arus_kas_wallet")
  @@index([tanggal_transaksi], map: "idx_project_arus_kas_tanggal")
  @@index([jenis_transaksi], map: "idx_project_arus_kas_jenis")
  @@index([kategori_transaksi], map: "idx_project_arus_kas_kategori")
  @@index([status_transaksi], map: "idx_project_arus_kas_status")
  @@index([id_project, wallet_key, tanggal_transaksi], map: "idx_project_arus_kas_project_wallet_tanggal")
  @@map("project_arus_kas")
}

// ── MOU: data pra-closing (dibuat saat buat transaksi) ───────────────────────
model Mou {
  id                    BigInt               @id @default(autoincrement())
  id_transaksi          String?              @unique @db.VarChar(50)
  id_listing            BigInt
  id_agent              String               @db.VarChar(20)
  id_klien              String?              @db.VarChar(20)
  jenis_transaksi       jenis_transaksi_enum
  tipe_komisi           String               @db.VarChar(50)
  gambar_ktp_klien      String?
  nama_lengkap_klien    String?              @db.VarChar(200)
  nik_klien             String?              @db.VarChar(20)
  alamat_klien          String?
  harga_deal            BigInt?
  harga_limit           Decimal?             @db.Decimal(20, 2)
  persentase_komisi     Decimal?             @db.Decimal(10, 6)
  biaya_baliknama       BigInt?
  biaya_pengosongan     BigInt?
  termasuk_baliknama    Boolean              @default(false)
  termasuk_pengosongan  Boolean              @default(false)
  maksimum_bidding      Decimal?             @db.Decimal(20, 2)
  agent_luar_nama       String?              @db.VarChar(100)
  agent_luar_kantor     String?              @db.VarChar(100)
  agent_luar_telepon    String?              @db.VarChar(20)
  tanggal_transaksi     DateTime?            @db.Date
  status                status_mou_enum      @default(proses)
  mou_generated         Boolean              @default(false)
  invoice_utm_generated Boolean              @default(false)
  dibuat_pada           DateTime             @default(now()) @db.Timestamptz(6)
  diperbarui_pada       DateTime             @default(now()) @db.Timestamptz(6)
  listing               Listing              @relation(fields: [id_listing], references: [id_property], map: "mou_listing_fk")
  agent                 Agent                @relation("MouAgent", fields: [id_agent], references: [id_agent], map: "mou_agent_fk")
  klien                 Pengguna?            @relation("MouKlien", fields: [id_klien], references: [id_pengguna], map: "mou_klien_fk")
  transaksi             Transaksi?

  @@index([id_listing], map: "mou_listing_idx")
  @@index([id_agent], map: "mou_agent_idx")
  @@map("mou")
}

// ── Transaksi: data realisasi closing (dibuat setelah closing dikonfirmasi) ───
model Transaksi {
  id_transaksi             String                @id @db.VarChar(50)
  harga_bidding            Decimal?              @db.Decimal(20, 2)
  selisih                  BigInt?
  kenaikan_dari_limit      Decimal?              @db.Decimal(10, 6)
  biaya_baliknama          BigInt?
  biaya_pengosongan        BigInt?
  cobroke_fee              BigInt                @default(0)
  tanggal_transaksi        DateTime              @db.Date
  rating                   Int?
  comment                  String?               @db.VarChar(250)
  catatan                  String?
  pendapatan_bersih_kantor BigInt                @default(0)
  thc_agent                BigInt                @default(0)
  status_transaksi         status_transaksi_enum @default(closing)
  dibuat_pada              DateTime              @default(now()) @db.Timestamptz(6)
  diperbarui_pada          DateTime              @default(now()) @db.Timestamptz(6)
  mou                      Mou                   @relation(fields: [id_transaksi], references: [id_transaksi], map: "transaksi_mou_fk")
  detail                   DetailTransaksi[]
  invoice                  Invoice[]

  @@index([tanggal_transaksi], map: "transaksi_date_idx")
  @@map("transaksi")
}

model DetailTransaksi {
  id           BigInt    @id @default(autoincrement())
  id_transaksi String    @db.VarChar(50)
  id_agent     String    @db.VarChar(50)
  role         String    @db.VarChar(50)
  pendapatan   BigInt
  agent        Agent     @relation(fields: [id_agent], references: [id_agent], onDelete: Cascade, map: "detail_transaksi_agent_fk")
  transaksi    Transaksi @relation(fields: [id_transaksi], references: [id_transaksi], onDelete: Cascade, map: "detail_transaksi_trans_fk")

  @@unique([id_transaksi, id_agent, role], map: "detail_transaksi_unique_per_role")
  @@index([id_agent], map: "detail_transaksi_agent_idx")
  @@index([id_transaksi], map: "detail_transaksi_trans_idx")
  @@map("detail_transaksi")
}

model Invoice {
  id_invoice       String    @id @db.VarChar(50)
  id_kuitansi      String?   @db.VarChar(50)
  id_transaksi     String    @db.VarChar(50)
  ditagihkan_ke    String    @db.VarChar(255)
  keterangan       String
  nominal          BigInt
  tanggal_invoice  DateTime  @db.Timestamptz(6)
  tanggal_kuitansi DateTime? @db.Timestamptz(6)
  transaksi        Transaksi @relation(fields: [id_transaksi], references: [id_transaksi], map: "invoice_transaksi_fk")

  @@index([id_transaksi], map: "idx_invoice_transaksi")
  @@index([tanggal_invoice], map: "idx_invoice_tanggal")
  @@map("invoice")
}

model ListingBoost {
  id_boost        BigInt   @id @default(autoincrement())
  id_listing      BigInt
  jenis_boost     String   @db.VarChar(30)
  sumber          String   @db.VarChar(30)
  tanggal_mulai   DateTime @db.Timestamptz(6)
  tanggal_selesai DateTime @db.Timestamptz(6)
  status          String   @default("SCHEDULED") @db.VarChar(20)
  tanggal_dibuat  DateTime @default(now()) @db.Timestamptz(6)
  listing         Listing  @relation(fields: [id_listing], references: [id_property], onDelete: Cascade, map: "listing_boost_listing_fk")

  @@index([id_listing], map: "listing_boost_listing_idx")
  @@index([status])
  @@index([tanggal_mulai, tanggal_selesai], map: "listing_boost_time_idx")
  @@map("listing_boost")
}

model Berita {
  id_berita        BigInt             @id @default(autoincrement())
  id_agent         String?            @db.VarChar(20)
  judul            String             @db.VarChar(255)
  slug             String             @unique @db.VarChar(300)
  ringkasan        String?            @db.VarChar(500)
  isi_berita       String
  gambar_utama     String?            @db.VarChar(500)
  galeri_gambar    String?
  kategori         String             @db.VarChar(50)
  tag              String?            @db.VarChar(255)
  penulis          String             @db.VarChar(100)
  sumber_berita    String?            @db.VarChar(200)
  status_publish   status_berita_enum @default(DRAFT)
  berita_unggulan  Boolean            @default(false)
  berita_utama     Boolean            @default(false)
  views            Int                @default(0)
  share            Int                @default(0)
  tanggal_publish  DateTime?          @db.Timestamptz(6)
  tanggal_dibuat   DateTime           @default(now()) @db.Timestamptz(6)
  tanggal_diupdate DateTime           @default(now()) @db.Timestamptz(6)
  agent            Agent?             @relation(fields: [id_agent], references: [id_agent])

  @@index([slug], map: "idx_berita_slug")
  @@index([kategori], map: "idx_berita_kategori")
  @@index([status_publish], map: "idx_berita_status")
  @@index([tanggal_publish], map: "idx_berita_tanggal")
  @@map("berita")
}

model RewardPoin {
  id_reward        BigInt          @id @default(autoincrement())
  nama_reward      String          @db.VarChar(200)
  slug             String          @unique @db.VarChar(300)
  deskripsi        String?
  gambar_reward    String?         @db.VarChar(500)
  kategori_reward  String          @db.VarChar(50)
  poin_dibutuhkan  Int
  stok             Int?
  aktif            Boolean         @default(true)
  tanggal_dibuat   DateTime        @default(now()) @db.Timestamptz(6)
