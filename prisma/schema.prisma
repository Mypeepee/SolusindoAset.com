  agent            Agent    @relation("AgentTarget", fields: [id_agent], references: [id_agent], onDelete: Cascade, map: "target_agent_agent_fk")

  @@unique([id_agent, tahun, bulan], map: "target_agent_unique")
  @@index([id_agent, tahun(sort: Desc), bulan(sort: Desc)], map: "target_agent_agent_period_idx")
  @@map("target_agent")
}

