/// Undangan acara — peserta yang di-invite ke sebuah acara di jadwal
/// agent. Berbeda dengan PesertaAcara (yang spesifik buat Pemilu
/// dengan semantic "memilih"), model ini murni untuk visibility
/// kalender: acara hanya tampil di kalender agent kalau dia owner
/// (Acara.id_agent) atau ada di tabel ini.
model UndanganAcara {
  id_undangan     BigInt              @id @default(autoincrement())
  id_acara        BigInt
  id_agent        String              @db.VarChar(20)
  status_undangan status_undangan_enum @default(DIUNDANG)
  diundang_pada   DateTime            @default(now()) @db.Timestamptz(6)
  direspon_pada   DateTime?           @db.Timestamptz(6)
  acara           Acara               @relation(fields: [id_acara], references: [id_acara], onDelete: Cascade)
  agent           Agent               @relation(fields: [id_agent], references: [id_agent], onDelete: Cascade)

  @@unique([id_acara, id_agent])
  @@index([id_agent], map: "idx_undangan_agent")
  @@index([id_acara], map: "idx_undangan_acara")
  @@map("undangan_acara")
}

model PesertaAcara {
